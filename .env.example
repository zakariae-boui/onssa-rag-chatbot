# Copy this file to `.env` and adjust as needed.
# Every variable is OPTIONAL — defaults live in src/onssa_rag/config.py.

# --- Ollama ---
# URL of the local Ollama server
OLLAMA_HOST=http://localhost:11434
# Any pulled open-source model. Low-RAM alternatives: llama3.2:3b, qwen2.5:3b
OLLAMA_MODEL=mistral:7b

# --- Embeddings (sentence-transformers model id, multilingual for French) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# --- RAG ---
# Chunks kept after RRF fusion (final context selection)
TOP_K=5
# Candidates per retriever (FAISS / BM25) before fusion
RETRIEVER_CANDIDATES=20
# Best cosine similarity below this -> "information non trouvee" fallback
SIMILARITY_THRESHOLD=0.30
# Context cap (characters) after parent-section expansion
MAX_CONTEXT_CHARS=8000
# Chunking (characters)
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# --- Ingestion ---
# Seconds between HTTP requests to onssa.gov.ma (politeness throttle)
REQUEST_DELAY=1.0
# Where the knowledge base lives
DATA_DIR=./data
# Identify yourself when scraping (recommended: add a contact address)
# USER_AGENT=ONSSA-RAG-Chatbot/0.1 (educational internship project; contact: you@example.com)
