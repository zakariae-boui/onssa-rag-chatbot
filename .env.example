# Copy this file to `.env` and adjust as needed.
# Every variable is OPTIONAL — defaults live in src/onssa_rag/config.py.

# --- Ollama ---
# URL of the local Ollama server
OLLAMA_HOST=http://localhost:11434
# Any pulled open-source model. Low-RAM alternatives: llama3.2:3b, qwen2.5:3b
OLLAMA_MODEL=mistral:7b
# Context window (Ollama's 4096 default can truncate our grounded prompts)
OLLAMA_NUM_CTX=8192
# Keep the model warm between questions (avoids ~20 s reloads mid-session)
OLLAMA_KEEP_ALIVE=30m

# --- Embeddings (sentence-transformers model id, multilingual for French) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# --- RAG ---
# Chunks kept after RRF fusion (final context selection)
TOP_K=5
# Candidates per retriever (FAISS / BM25) before fusion
RETRIEVER_CANDIDATES=20
# Relevance gate: fallback answer unless one leg shows a confident hit.
# Both values calibrated empirically for multilingual-e5-base (see config.py).
SIMILARITY_THRESHOLD=0.825
BM25_GATE=12.0
# BM25 precision leg: only its top hits join the fusion, at full weight
# (values chosen by eval sweep — see README)
BM25_WEIGHT=1.0
BM25_CANDIDATES=5
# Context cap (characters) after parent-section expansion.
# Lower = faster on CPU, higher = more grounding; 6000 is the laptop sweet spot.
MAX_CONTEXT_CHARS=6000
# Chunking (characters)
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# --- Voice (local, CPU) ---
# faster-whisper model for the mic input: tiny (fastest) / base / small (recommended) / medium
WHISPER_MODEL=small
# Piper French voice for reading answers aloud (auto-downloaded on first use)
PIPER_VOICE=fr_FR-siwis-medium

# --- Ingestion ---
# Seconds between HTTP requests to onssa.gov.ma (politeness throttle)
REQUEST_DELAY=1.0
# Where the knowledge base lives
DATA_DIR=./data
# Identify yourself when scraping (recommended: add a contact address)
# USER_AGENT=ONSSA-RAG-Chatbot/0.1 (educational internship project; contact: you@example.com)
